[[ -n "${__LIB_TOOLS_LOADED__}" ]] && return 0
readonly __LIB_TOOLS_LOADED__="YES"


# Tools ------------------------------------------------

# If the folder does not exist, it will be created.
check:folder ()
{
    [[ -d ./$1 ]] && return
    mkdir -p "$1"
} 


# Creating folders alphabetically
first_char=""
check:archive_folder ()
{
    first_char=$(grep -o '^.' <<< "$1" | tr '[:upper:]' '[:lower:]')
    check:folder .tmp_archive/$first_char
}


# WARNING:
# This function assumes the caller has already initialized the
# starting coordinates (x, y). Behaviour is undefined otherwise.
#
# A matching call to end_field() is required after the last
# read_field() invocation. Failure to do so may leave the form
# state inconsistent.
y=1 && x=1 
field:read()
{

    read -e -r -p "${1}" "${2}"
    local value=${!2}
    local columns=$(tput cols)
    local offset=${3:-1}

    [[ -z $columns || $columns -le 0 ]] && return 0

    (( x += ${#value} + ${#1} + $offset ))

    if (( x >= columns )); then
        (( y += x / columns ))
        (( x %= columns ))
        (( x == 0 )) && x=1
    fi

    printf '\033[%d;%dH' "$y" "$x"
}
field:end ()
{
    x=1 && y=1
    printf "\n"
}

# check terminal width; compute line count for input string.
count:line ()
{
    local len=${#1}
    local columns

    columns=$(tput cols 2>/dev/null)
    (( columns <= 0 )) && { echo 0; return; }

    if (( len > columns )); then
        echo $(( (len + columns - 1) / columns ))
        return
    elif (( len > 0 )); then
        echo 1
    else
        echo 0
    fi
}


# If the mirror is not configured in this session, the user will be asked a question.
tui:mirror:source ()
{

    local name_mirror="default"
    local dists=""
    local components=""
    local arch=""

    local mirror_field=0

    local ask_msg="If you have already set up a mirror source and want to enter it here, otherwise you will need to configure a new mirror from scratch. (y/n)" 
    local address_mirror_msg="Please_set_address_mirror:"

    echo "test $(count:line "${ask_msg}")"
    x=1 && ((y = $(count:line "${ask_msg}") + 1 ))
    
    clear

    color:start ${blue}
    read -p "${ask_msg}" ask
    color:end


    if [[ ${ask} =~ ^([yY]|[yY][eE][sS])$ ]]; then 
        mirror_field=1
    else 
        
        color:start ${purple}
        read -p "${address_mirror_msg}" mirror
        color:end 
        
        mirror:source "${mirror}" default

        ((y += $(count:line "${address_mirror_msg}")))

    fi 
    

    color:start ${purple}

    (( mirror_field )) && field:read "mirror:" name_mirror 2
    field:read "dists:" dists 2
    field:read "components:" components 2 
    field:read "arch:" arch 2
    field:end

    color:end
    
    mirror:default ${name_mirror} ${dists} ${components} ${arch}
}


# Print text using a standard ANSI foreground color.
readonly red=31
readonly green=32
readonly yellow=33
readonly blue=34
readonly purple=35

readonly pipeline_error=1
readonly pipeline_normal=0
readonly no_new_line=1

color:print ()
{

    local target="/dev/tty"

    (( ${3:-0} )) && target="/dev/stderr"

    printf "\033[1;${2}m${1}\033[0m" > "$target"
    [[ -z ${4} ]] && printf "\n" > "$target"
}  


# begin color block
color:start()
{
    printf "\033[1;${1}m"
}
# end color block
color:end()
{
    printf "\033[0m"
}

# Print text using a 256-color foreground.
color256:print ()
{

    exec 3>&1

    local pipeline=3

    [[ -z "${3}" ]] && pipeline=2

    printf "\033[38;5;${2}m${1}\033[0m" >&${pipeline}
    [[ -z "$3" ]] && printf "\n" >&${pipeline}

    exec 3>&-

}
# begin color256 block
color256:start ()
{
    printf "\033[38;5;${1}m"
}
# end color256 block
color256:end ()
{
    printf "\033[0m"
}


# log success = name func + msg.
log:success ()
{
    log:show "${1}" "${2}" ${blue} ${green} ${pipeline_normal}
}

# log failure = name func + msg.
log:failure ()
{
    log:show "${1}" "${2}" ${blue} ${red} ${pipeline_error}
}

# log waring = name func + msg.
log:waring ()
{
    log:show "${1}" "${2}" ${blue} ${yellow} ${pipeline_normal}
}

# log show = func name + err with + custom color.
log:show ()
{
    color:print "${1} " "${3}" "${5}" ${no_new_line}
    color:print "${2}"  "${4}" "${5}"
}

# check if string exists in array.
str:found_match ()
{
    local str=${1}
    local target=${2}

    [[ ! ${target} ]] && return 0

    for arg in ${str}; do
        [[ "${target}" == "${arg}" ]] && return 0
        echo "target:${target} arg:${arg}"
    done 

    return 1
}

# clean all temp ‍packages.
clean ()
{
    rm -rf -- .tmp_archive
}

